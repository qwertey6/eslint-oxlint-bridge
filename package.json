{
  "name": "eslint-oxlint-bridge",
  "version": "0.1.0",
  "description": "ESLint plugin that bridges oxlint diagnostics into ESLint's reporting pipeline",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.cjs",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc && cp src/index.cjs dist/index.cjs",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "prepublishOnly": "npm run build && npm test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/qwertey6/eslint-oxlint-bridge.git"
  },
  "bugs": {
    "url": "https://github.com/qwertey6/eslint-oxlint-bridge/issues"
  },
  "homepage": "https://github.com/qwertey6/eslint-oxlint-bridge#readme",
  "keywords": [
    "eslint",
    "eslintplugin",
    "eslint-plugin",
    "oxlint",
    "oxc",
    "linter",
    "bridge",
    "type-aware"
  ],
  "author": "qwertey6",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "peerDependencies": {
    "eslint": ">=9.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "typescript": "^5.0.0",
    "vitest": "^3.0.0"
  }
}
